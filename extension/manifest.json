{
  "manifest_version": 3,
  "name": "BLOSCOM-AI",
  "version": "1.0",
  "description": "Right-click any page to get AI help from BLOSCOM-AI",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    { "resources": ["logo.png", "icon.png"], "matches": ["<all_urls>"] }
  ],
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "BLOSCOM-AI"
  }
}
